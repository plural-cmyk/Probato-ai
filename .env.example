# Primary Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Secondary Database (Neon PostgreSQL) — dual-write during migration
# Leave empty to use Supabase only. Fill in to enable dual-write.
NEON_DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-domain.vercel.app

# GitHub OAuth
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Browser Automation (Browserless)
BROWSERLESS_TOKEN=your-browserless-token

# Payment Gateway
PAYMENT_GATEWAY=mock

# Supabase (for client-side if needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Neon Auth (if still using Neon for auth during migration)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
