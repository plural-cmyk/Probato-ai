{
  "name": "@probato/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for the Probato AI Testing Platform API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["probato", "testing", "ai", "playwright", "automation", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/probato/probato-sdk"
  },
  "homepage": "https://probato.ai/docs/api"
}
