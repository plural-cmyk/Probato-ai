// Probato - AI-Powered Autonomous Testing Platform
// Prisma Schema with NextAuth + Domain Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================
// NextAuth Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Probato Domain Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubId      String?   @unique
  githubLogin   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  projects   Project[]
  schedules  Schedule[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  repoUrl     String
  repoName    String
  branch      String   @default("main")
  status      String   @default("pending") // pending, cloning, ready, error
  sandboxId   String?  // Docker container ID
  sandboxUrl  String?  // URL where sandboxed app is accessible
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  features  Feature[]
  testRuns  TestRun[]
  schedules Schedule[]

  @@index([userId])
}

model Feature {
  id          String   @id @default(cuid())
  name        String
  type        String   // route, component, form, api-endpoint, page
  path        String?  // File path in repo
  route       String?  // URL route (for pages/API routes)
  selector    String?  // Primary CSS selector (for components/forms)
  description String?
  priority    Int      @default(0) // For topological sort ordering
  dependencies String[] @default([]) // Feature IDs this depends on
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]

  @@index([projectId])
  @@index([type])
}

model TestRun {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, running, passed, failed, error
  triggeredBy String @default("manual") // manual, auto, auto-heal, push, pr, schedule
  startedAt DateTime?
  endedAt   DateTime?
  logs      String?  // Raw test output
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results    TestResult[]

  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([scheduleId])
}

model TestResult {
  id          String   @id @default(cuid())
  testName    String
  featureName String?
  status      String   // passed, failed, skipped, error
  duration    Int?     // milliseconds
  error       String?  // Error message if failed
  screenshot  String?  // Base64 screenshot on failure
  createdAt   DateTime @default(now())

  testRunId String
  testRun   TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([testRunId])
  @@index([status])
}

model TestCase {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   // Generated Playwright test code
  selector    String?  // Primary selector used in the test
  autoHealed  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
}

// ============================================
// Phase 2: CI/CD Integration Models
// ============================================

model Installation {
  id                String   @id @default(cuid())
  githubInstallationId Int   @unique // GitHub App installation ID
  accountId         Int?     // GitHub account (org/user) ID
  accountLogin      String?  // GitHub account login
  accountType       String?  // "User" or "Organization"
  accessToken       String?  // Installation access token (encrypted)
  tokenExpiresAt    DateTime?
  repositorySelection String? @default("selected") // "all" or "selected"
  status            String   @default("active") // active, suspended, deleted
  installedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  webhookEvents WebhookEvent[]
  repositories  Repository[]

  @@index([githubInstallationId])
  @@index([status])
}

model Repository {
  id              String   @id @default(cuid())
  githubRepoId    Int      @unique // GitHub repository ID
  name            String   // e.g. "plural-cmyk/Probato-ai"
  fullName        String   // e.g. "Probato-ai"
  private         Boolean  @default(false)
  defaultBranch   String   @default("main")
  htmlUrl         String?
  projectId       String?  // Link to Probato project
  enabled         Boolean  @default(true) // User can disable per-repo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installationId  String
  installation    Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([githubRepoId])
}

model WebhookEvent {
  id                String   @id @default(cuid())
  githubDeliveryId  String?  // X-GitHub-Delivery header
  event             String   // push, pull_request, installation, etc.
  action            String?  // opened, synchronize, closed, etc.
  payload           Json     // Full webhook payload
  processed         Boolean  @default(false)
  processingError   String?  // Error if processing failed
  triggeredTestRunId String? // Link to the test run triggered by this event
  createdAt         DateTime @default(now())
  processedAt       DateTime?

  installationId String?
  installation   Installation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([event])
  @@index([processed])
  @@index([installationId])
  @@index([createdAt])
}

// ============================================
// Phase 2: Scheduled & Recurring Tests
// ============================================

model Schedule {
  id              String   @id @default(cuid())
  name            String   // Human-readable name, e.g. "Daily Smoke Test"
  url             String   // Target URL to test
  preset          String   @default("smoke") // smoke, navigation, login, form, full-page-screenshot
  cronExpression  String   // Cron expression, e.g. "*/30 * * * *", "0 9 * * 1-5"
  enabled         Boolean  @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?  // passed, failed, error
  lastRunId       String?  // Link to last TestRun
  nextRunAt       DateTime? // Calculated next execution time
  runCount        Int      @default(0)
  failCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  testRuns        TestRun[]

  @@index([userId])
  @@index([enabled])
  @@index([nextRunAt])
}
