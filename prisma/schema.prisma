  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId            String?
  testRun              TestRun?  @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  orchestratedSessionId String?  @unique
  orchestratedSession   OrchestratedSession? @relation(fields: [orchestratedSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// Phase 6: AI Test Intelligence (M29)
// ============================================

model TestDependencyGraph {
  id              String   @id @default(cuid())
  testCaseId      String
  projectId       String
  sourcePath      String   // File path in repo
  functionName    String?  // Function or component name
  dependencyType  String   // import, call, render, navigate, api_call
  confidence      Float    @default(0) // 0-1 confidence score
  lastVerifiedAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  testCase        TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@index([projectId])
  @@index([sourcePath])
  @@index([dependencyType])
  @@unique([testCaseId, sourcePath, functionName, dependencyType])
}

model SmartSelectionResult {
  id              String   @id @default(cuid())
  projectId       String
  triggeringFiles Json     @default("[]") // Array of changed file paths
  selectedTests   Json     @default("[]") // Array of selected testCase IDs
  skippedTests    Json     @default("[]") // Array of skipped testCase IDs
  rationale       String?  // AI-generated explanation
  coveragePercent Float    @default(0) // Estimated coverage of changes
  actualOutcomes  Json?    // Filled after test run: pass/fail/skip per test
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model FlakinessReport {
  id                String   @id @default(cuid())
  testCaseId        String
  flakinessScore    Int      @default(0)   // 0-100
  classification    String   @default("unknown") // stable, flaky, failing, unknown
  primaryIndicator  String?  // timing, order_dependency, resource_contention, external_dependency
  confidence        Float    @default(0)   // 0-1
  recentOutcomes    Json     @default("[]") // Last 10 run outcomes as JSON array
  lastAnalyzedAt    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  testCase          TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  alerts            FlakinessAlert[]

  @@unique([testCaseId])
  @@index([classification])
  @@index([flakinessScore])
}

model FlakinessAlert {
  id              String   @id @default(cuid())
  testCaseId      String
  testRunId       String?  // The run that triggered this alert
  alertType       String   // new_flaky, score_increase, pattern_detected
  message         String
  previousScore   Int?
  currentScore    Int?
  dismissed       Boolean  @default(false)
  createdAt       DateTime @default(now())

  flakinessReport FlakinessReport @relation(fields: [flakinessReportId], references: [id], onDelete: Cascade)
  flakinessReportId String

  @@index([testCaseId])
  @@index([alertType])
  @@index([dismissed])
  @@index([createdAt])
}

model ImpactAnalysisResult {
  id              String   @id @default(cuid())
  projectId       String
  triggeringFiles Json     @default("[]") // Changed files
  priorityOrder   Json     @default("[]") // Ordered array of { testCaseId, priorityScore, reason }
  totalAffected   Int      @default(0)
  criticalCount   Int      @default(0)
  highCount       Int      @default(0)
  mediumCount     Int      @default(0)
  lowCount        Int      @default(0)
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

// ============================================
// Phase 6: Self-Healing Tests v2 & Auto-Maintenance (M30)
// ============================================

model SelectorRepair {
  id              String   @id @default(cuid())
  testCaseId      String
  oldSelector     String   // The selector that broke
  newSelector     String   // The healed replacement selector
  confidence      Float    @default(0) // 0-1 confidence score
  status          String   @default("pending") // pending, approved, rejected, applied, reverted
  domSnapshot     Json?    // DOM snapshot before and after repair
  verifiedAt      DateTime? // When the repair was verified by re-running
  appliedAt       DateTime?
  appliedBy       String?  // User ID who approved
  reviewNote      String?
  testRunId       String?  // Test run that verified the repair
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  testCase        TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@index([status])
  @@index([confidence])
  @@index([createdAt])
}

model TestMaintenanceRecord {
  id              String   @id @default(cuid())
  projectId       String
  testCaseId      String?
  category        String   // deprecation, assertion_drift, step_staleness, code_quality
  severity        String   // critical, warning, info
  title           String
  description     String
  suggestedDiff   String?  // Unified diff of suggested code change
  effort          Int      @default(0) // 1-5 effort score
  status          String   @default("open") // open, in_progress, resolved, dismissed
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([testCaseId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// M31: Synthetic Monitoring & Performance Baselines
// ============================================

model SyntheticCheckpoint {
  id              String   @id @default(cuid())
  name            String   // Human-readable name, e.g. "Homepage Load Check"
  url             String   // Production URL to monitor
  steps           Json     @default("[]") // Array of interaction steps: [{type:"navigate",value:"/"},{type:"assert",selector:"h1",value:"Welcome"}]
  expectedOutcome String?  // Description of expected outcome
  intervalMinutes Int      @default(5) // Min 5 minutes between checks
  severity        String   @default("informational") // critical, informational
  enabled         Boolean  @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?  // passed, failed, error
  runCount        Int      @default(0)
  failCount       Int      @default(0)
  avgResponseTime Float    @default(0) // Average response time in ms
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  results         CheckpointResult[]

  @@index([userId])
  @@index([projectId])
  @@index([enabled])
  @@index([severity])
  @@index([createdAt])
}

model CheckpointResult {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, passed, failed, error
  responseTime    Int      @default(0) // Total response time in ms
  screenshot      String?  // Base64 screenshot on failure
  error           String?  // Error message if failed
  stepResults     Json     @default("[]") // Per-step results with timing
  lcp             Float?   // Largest Contentful Paint
  fid             Float?   // First Input Delay
  cls             Float?   // Cumulative Layout Shift
  ttfb            Float?   // Time to First Byte
  domContentLoaded Float?  // DOM Content Loaded time
  fullPageLoad    Float?   // Full page load time
  createdAt       DateTime @default(now())

  checkpointId    String
  checkpoint      SyntheticCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId])
  @@index([status])
  @@index([createdAt])
}

model PerformanceBaseline {
  id              String   @id @default(cuid())
  url             String   // URL this baseline covers
  metricName      String   // lcp, fid, cls, ttfb, domContentLoaded, fullPageLoad
  mean            Float    @default(0)
  stdDev          Float    @default(0)
  p50             Float    @default(0)
  p75             Float    @default(0)
  p95             Float    @default(0)
  sampleCount     Int      @default(0) // Rolling window of last 30 successful executions
  warningThreshold Float   @default(20) // 20% degradation = warning
  criticalThreshold Float  @default(50) // 50% degradation = critical
  lastComputedAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  regressions     PerformanceRegression[]

  @@unique([url, metricName, projectId])
  @@index([projectId])
  @@index([url])
  @@index([metricName])
}

model PerformanceRegression {
  id              String   @id @default(cuid())
  metricName      String   // lcp, fid, cls, ttfb, domContentLoaded, fullPageLoad
  currentValue    Float    // Current observed value
  baselineValue   Float    // Baseline expected value
  degradationPercent Float  // Percentage of degradation
  severity        String   @default("warning") // warning, critical
  status          String   @default("open") // open, acknowledged, resolved, dismissed
  screenshot      String?  // Screenshot at time of regression
  deploymentInfo  Json?    // Deployment correlation data
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  baselineId      String
  baseline        PerformanceBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([baselineId])
  @@index([projectId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// M32: Enterprise SSO, Audit & Compliance, RBAC v2
// ============================================

model SSOConfiguration {
  id              String   @id @default(cuid())
  protocol        String   @default("saml") // saml, oidc
  label           String   // e.g. "Okta SSO", "Azure AD"
  enabled         Boolean  @default(true)
  
  // SAML-specific fields
  samlEntryUrl    String?  // IdP SSO URL
  samlLogoutUrl   String?  // IdP SLO URL
  samlCertificate String?  // IdP X.509 certificate
  samlIssuer      String?  // IdP Entity ID
  
  // OIDC-specific fields
  oidcClientId     String?
  oidcClientSecret String?  // Encrypted
  oidcDiscoveryUrl String?  // .well-known/openid-configuration
  oidcScopes       String[] @default(["openid", "email", "profile"])
  
  // Group-to-role mapping
  groupRoleMapping Json     @default("{}") // { "engineering": "member", "managers": "admin" }
  
  // Domain restrictions
  allowedDomains   String[] @default([]) // e.g. ["company.com"]
  
  // Auto-provisioning
  autoProvision    Boolean  @default(true) // Auto-create users on first SSO login
  
  status          String   @default("active") // active, disabled, testing
  lastTestedAt    DateTime?
  lastError       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teamId          String   @unique // One SSO config per team
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([protocol])
  @@index([status])
}

model AuditLog {
  id              String   @id @default(cuid())
  action          String   // e.g. "project.create", "test.run", "user.login", "sso.config.update"
  resource        String   // Resource type: project, test_run, user, team, etc.
  resourceId      String?  // ID of the affected resource
  resourceType    String?  // Type of the affected resource
  
  // Who performed the action
  userId          String?
  userEmail       String?
  userName        String?
  
  // Context
  ipAddress       String?
  userAgent       String?
  
  // What changed
  beforeSnapshot  Json?    // State before the change
  afterSnapshot   Json?    // State after the change
  metadata        Json?    // Additional context
  
  // Tamper-evident hash chain
  previousHash    String?  // SHA-256 hash of the previous audit log entry
  entryHash       String   // SHA-256 hash of this entry (computed from all fields + previousHash)
  chainValid      Boolean  @default(true) // Whether this entry's hash chain is valid
  
  // Severity for filtering
  severity        String   @default("info") // info, warning, critical
  
  createdAt       DateTime @default(now())

  teamId          String?  // Team context
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([userId])
  @@index([teamId])
  @@index([createdAt])
  @@index([severity])
}

model AuditLogExport {
  id              String   @id @default(cuid())
  name            String   // e.g. "Weekly SIEM Export"
  destination     String   // splunk, datadog, aws_cloudtrail, webhook
  config          Json     @default("{}") // Destination-specific config (URLs, tokens, etc.)
  retention       String   @default("90d") // 90d, 180d, 1y, indefinite
  
  schedule        String   @default("weekly") // daily, weekly, monthly
  enabled         Boolean  @default(true)
  lastExportAt    DateTime?
  lastError       String?
  exportCount     Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teamId          String
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([destination])
  @@index([enabled])
}

model PermissionPolicy {
  id              String   @id @default(cuid())
  name            String   // e.g. "Test Runner", "Project Admin", "Viewer"
  description     String?
  isDefault       Boolean  @default(false) // System-defined vs custom
  
  // Permissions included in this policy
  permissions     Json     @default("[]") // [{resource:"projects",actions:["read","write"]},{resource:"test_runs",actions:["read","execute"]}]
  
  // Conditions
  conditions      Json?    // [{type:"time_of_day",start:"09:00",end:"18:00",timezone:"UTC"},{type:"ip_allowlist",ips:["10.0.0.0/8"]}]
  
  // Scope
  scope           String   @default("team") // team, project, global
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teamId          String?  // Null for global default policies
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  resources       ResourcePermission[]

  @@index([teamId])
  @@index([scope])
  @@index([isDefault])
}

model ResourcePermission {
  id              String   @id @default(cuid())
  resourceType    String   // project, test_run, feature, etc.
  resourceId      String   // ID of the resource
  userId          String   // User who has this permission
  policyId        String?  // Permission policy applied
  customActions   Json     @default("[]") // Override actions: ["read","write","delete"]
  
  // Delegated admin
  delegatedBy     String?  // User ID who delegated
  delegatedAt     DateTime?
  expiresAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  policy          PermissionPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, userId])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@index([policyId])
  @@index([expiresAt])
}

// ============================================
// M33: Plugin Architecture & Integrations Marketplace
// ============================================

model Plugin {
  id              String   @id @default(cuid())
  name            String   // Plugin name (npm package style, e.g. "@probato/jira-integration")
  version         String   // Semver version
  description     String?
  author          String?
  homepage        String?  // URL to plugin docs/source
  
  // Manifest
  manifest        Json     @default("{}") // Full probato-plugin.json manifest: extensionPoints, permissions, config schema
  
  // Extension points
  extensionPoints Json     @default("[]") // [{type:"test_executor",id:"jira-test-runner"},{type:"notification_channel",id:"jira-notification"}]
  permissions     Json     @default("[]") // ["read:projects","write:test_runs","read:features"]
  
  // State
  tier            String   @default("community") // official, verified, community
  status          String   @default("installed") // installed, active, deactivated, error
  enabled         Boolean  @default(false)
  
  // Configuration
  config          Json     @default("{}") // Plugin-specific configuration values
  
  // Integrity
  checksum        String?  // SHA-256 of the plugin package
  signature       String?  // Digital signature for verified/official plugins
  
  // Runtime stats
  executionCount  Int      @default(0)
  lastExecutedAt  DateTime?
  lastError       String?
  
  // Private plugin flag
  isPrivate       Boolean  @default(false) // Team-only, not visible on marketplace
  
  installedAt     DateTime @default(now())
  activatedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teamId          String   // Plugins are installed at team level
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  installedBy     String?  // User ID who installed
  executions      PluginExecution[]

  @@unique([teamId, name])
  @@index([teamId])
  @@index([status])
  @@index([tier])
  @@index([enabled])
  @@index([createdAt])
}

model PluginExecution {
  id              String   @id @default(cuid())
  extensionPoint  String   // Which extension point was invoked
  input           Json     @default("{}") // Input parameters
  output          Json     @default("{}") // Output results
  
  // Resource consumption
  durationMs      Int      @default(0) // Execution time in ms
  memoryUsedKb    Int      @default(0) // Peak memory usage
  cpuTimeMs       Int      @default(0) // CPU time consumed
  
  // Result
  status          String   @default("completed") // completed, error, timeout, killed
  error           String?  // Error message if failed
  
  createdAt       DateTime @default(now())

  pluginId        String
  plugin          Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  triggeredBy     String?  // User ID or "system" if automated

  @@index([pluginId])
  @@index([status])
  @@index([extensionPoint])
  @@index([createdAt])
}

model MarketplaceListing {
  id              String   @id @default(cuid())
  name            String   // Plugin name
  version         String   // Latest version
  description     String
  longDescription String?  // Markdown long description
  author          String
  homepage        String?
  repository      String?  // Source code URL
  
  // Classification
  category        String   @default("integration") // integration, test_runner, notification, analytics, utility
  tier            String   @default("community") // official, verified, community
  tags            String[] @default([])
  
  // Marketplace metadata
  iconUrl         String?  // Plugin icon/logo
  screenshots     Json     @default("[]") // Array of screenshot URLs
  
  // Stats
  installCount    Int      @default(0)
  avgRating       Float    @default(0)
  reviewCount     Int      @default(0)
  
  // Requirements
  requiredPermissions Json  @default("[]") // Permissions this plugin requires
  minProbatoVersion String? // Minimum Probato version required
  extensionPoints Json     @default("[]") // Extension points provided
  configSchema   Json     @default("{}") // JSON Schema for plugin configuration
  
  // Package
  packageUrl      String?  // URL to download the plugin package
  checksum        String?  // SHA-256 of the latest package
  signature       String?  // Digital signature
  
  // Status
  status          String   @default("published") // draft, published, deprecated, removed
  featured        Boolean  @default(false) // Featured on marketplace homepage
  
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviews         MarketplaceReview[]

  @@unique([name])
  @@index([category])
  @@index([tier])
  @@index([status])
  @@index([featured])
  @@index([installCount])
  @@index([createdAt])
}

model MarketplaceReview {
  id              String   @id @default(cuid())
  rating          Int      // 1-5 stars
  title           String?
  content         String?  // Review text
  version         String?  // Version of plugin at time of review
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listingId       String
  listing         MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  userId          String
  userName        String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId]) // One review per user per listing
  @@index([listingId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}
