  callFlowEvents      Json      @default("[]")        // Ordered array of call flow events
  callPhaseChecks     Json      @default("[]")        // Array of CallPhaseCheckResult objects
  audioChecks         Json      @default("[]")        // Array of AudioCheckResult objects
  overallScore        Int       @default(0)           // 0-100 call flow health score
  connectionScore     Int       @default(0)           // 0-100 call connection score
  audioScore          Int       @default(0)           // 0-100 audio quality score
  callFlowScore       Int       @default(0)           // 0-100 call flow correctness score
  findings            Json      @default("[]")        // Aggregated findings
