  testRun             TestRun?  @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  orchestratedSessionId String?  @unique
  orchestratedSession   OrchestratedSession? @relation(fields: [orchestratedSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// Phase 5: Payment Flow Testing (M28)
