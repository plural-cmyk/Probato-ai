  webhookDeliveryMsP95  Int       @default(0)           // Webhook delivery p95 latency in ms
  paymentResults       Json      @default("[]")        // Array of per-scenario payment results
  checkoutSteps        Json      @default("[]")        // Array of CheckoutStepResult objects
  webhookChecks        Json      @default("[]")        // Array of WebhookCheckResult objects
  findings             Json      @default("[]")        // Aggregated findings
