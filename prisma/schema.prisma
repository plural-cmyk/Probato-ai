  duration             Int       @default(0)           // Total test duration in ms
  error                String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  projectId            String?
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

