  conversationFlow    Json      @default("[]")        // Ordered array of conversation events
  messageChecks       Json      @default("[]")        // Array of MessageCheckResult objects
  notificationChecks  Json      @default("[]")        // Array of NotificationCheckResult objects
  deliveryChecks      Json      @default("[]")        // Array of DeliveryCheckResult objects
  overallScore        Int       @default(0)           // 0-100 messaging health score
  messageScore        Int       @default(0)           // 0-100 message delivery score
  notificationScore   Int       @default(0)           // 0-100 notification score
  deliveryScore       Int       @default(0)           // 0-100 delivery receipt score
  findings            Json      @default("[]")        // Aggregated findings
  recommendations     Json      @default("[]")        // Array of recommendation strings
  llmUsed             Boolean   @default(false)
  duration            Int       @default(0)           // Total test duration in ms
