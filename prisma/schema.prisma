// Probato - AI-Powered Autonomous Testing Platform
// Prisma Schema with NextAuth + Domain Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================
// NextAuth Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Probato Domain Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubId      String?   @unique
  githubLogin   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  schedules       Schedule[]
  visualBaselines VisualBaseline[]
  notifications          Notification[]
  notificationChannels   NotificationChannel[]
  notificationPreferences NotificationPreference[]
  subscription           Subscription?
  creditBalance          CreditBalance?
  creditTransactions     CreditTransaction[]
  apiKeys                ApiKey[]
  securityScans          SecurityScan[]
  securityProbes         SecurityProbe[]
  apiProbes              APIProbe[]
  a11yAudits             A11yAudit[]
  mediaVerifications     MediaVerification[]
  orchestratedSessions   OrchestratedSession[]
  messagingTestSessions  MessagingTestSession[]
  callFlowTestSessions  CallFlowTestSession[]
  paymentFlowTestSessions PaymentFlowTestSession[]
  onboardingState        OnboardingState?
  teamMemberships        TeamMember[]
  sentInvitations        TeamInvitation[]  @relation("SentInvitations")
  receivedInvitations    TeamInvitation[]  @relation("ReceivedInvitations")
  comments               Comment[]
  sharedWithMe           SharedProject[]   @relation("SharedWithUser")
  ownedTeams             Team[]            @relation("OwnedTeams")
  sharedProjects         SharedProject[]   @relation("SharedProjects")
  resourcePermissions    ResourcePermission[]
  syntheticCheckpoints   SyntheticCheckpoint[]
  marketplaceReviews     MarketplaceReview[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  repoUrl     String   @default("")
  repoName    String   @default("")
  liveUrl     String?  // Live URL for URL-based testing (no Docker needed)
  source      String   @default("repo") // "repo" or "url" — how the project was created
  branch      String   @default("main")
  status      String   @default("pending") // pending, cloning, ready, running, error
  sandboxId   String?  // Docker container ID
  sandboxUrl  String?  // URL where sandboxed app is accessible
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  features        Feature[]
  testRuns        TestRun[]
  schedules       Schedule[]
  visualBaselines VisualBaseline[]
  visualDiffs     VisualDiff[]
  notifications   Notification[]
  fixSuggestions  FixSuggestion[]
  securityScans   SecurityScan[]
  securityProbes  SecurityProbe[]
  apiProbes       APIProbe[]
  a11yAudits      A11yAudit[]
  mediaVerifications MediaVerification[]
  orchestratedSessions OrchestratedSession[]
  messagingTestSessions MessagingTestSession[]
  callFlowTestSessions CallFlowTestSession[]
  paymentFlowTestSessions PaymentFlowTestSession[]
  comments        Comment[]
  sharedWith      SharedProject[]
  dependencyEdges    TestDependencyGraph[]
  smartSelections    SmartSelectionResult[]
  impactAnalyses     ImpactAnalysisResult[]
  maintenanceRecords TestMaintenanceRecord[]
  syntheticCheckpoints  SyntheticCheckpoint[]
  performanceBaselines  PerformanceBaseline[]
  performanceRegressions PerformanceRegression[]

  @@index([userId])
  @@index([teamId])
}

model Feature {
  id          String   @id @default(cuid())
  name        String
  type        String   // route, component, form, api-endpoint, page
  path        String?  // File path in repo
  route       String?  // URL route (for pages/API routes)
  selector    String?  // Primary CSS selector (for components/forms)
  description String?
  priority    Int      @default(0) // For topological sort ordering
  dependencies String[] @default([]) // Feature IDs this depends on
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]
  riskScore FeatureRiskScore?

  @@index([projectId])
  @@index([type])
}

model TestRun {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, running, passed, failed, error
  triggeredBy String @default("manual") // manual, auto, auto-heal, push, pr, schedule
  startedAt DateTime?
  endedAt   DateTime?
  logs      String?  // Raw test output
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results    TestResult[]

  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  visualDiffs VisualDiff[]
  notifications Notification[]
  fixSuggestions FixSuggestion[]
  securityScans   SecurityScan[]
  securityProbes  SecurityProbe[]
  apiProbes       APIProbe[]
  a11yAudits      A11yAudit[]
  mediaVerifications MediaVerification[]
  orchestratedSessions OrchestratedSession[]
  messagingTestSessions MessagingTestSession[]
  callFlowTestSessions CallFlowTestSession[]
  paymentFlowTestSessions PaymentFlowTestSession[]
  comments        Comment[]

  @@index([projectId])
  @@index([status])
  @@index([scheduleId])
}

model TestResult {
  id          String   @id @default(cuid())
  testName    String
  featureName String?
  status      String   // passed, failed, skipped, error
  duration    Int?     // milliseconds
  error       String?  // Error message if failed
  screenshot  String?  // Base64 screenshot on failure
  createdAt   DateTime @default(now())

  testRunId String
  testRun   TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  fixSuggestions FixSuggestion[]

  @@index([testRunId])
  @@index([status])
}

model TestCase {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   // Generated Playwright test code
  selector    String?  // Primary selector used in the test
  autoHealed  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  fixSuggestions FixSuggestion[]
  dependencies  TestDependencyGraph[]
  flakinessReport FlakinessReport?
  selectorRepairs SelectorRepair[]

  @@index([featureId])
}

// ============================================
// Phase 2: CI/CD Integration Models
// ============================================

model Installation {
  id                String   @id @default(cuid())
  githubInstallationId Int   @unique // GitHub App installation ID
  accountId         Int?     // GitHub account (org/user) ID
  accountLogin      String?  // GitHub account login
  accountType       String?  // "User" or "Organization"
  accessToken       String?  // Installation access token (encrypted)
  tokenExpiresAt    DateTime?
  repositorySelection String? @default("selected") // "all" or "selected"
  status            String   @default("active") // active, suspended, deleted
  installedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  webhookEvents WebhookEvent[]
  repositories  Repository[]

  @@index([githubInstallationId])
  @@index([status])
}

model Repository {
  id              String   @id @default(cuid())
  githubRepoId    Int      @unique // GitHub repository ID
  name            String   // e.g. "plural-cmyk/Probato-ai"
  fullName        String   // e.g. "Probato-ai"
  private         Boolean  @default(false)
  defaultBranch   String   @default("main")
  htmlUrl         String?
  projectId       String?  // Link to Probato project
  enabled         Boolean  @default(true) // User can disable per-repo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installationId  String
  installation    Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([githubRepoId])
}

model WebhookEvent {
  id                String   @id @default(cuid())
  githubDeliveryId  String?  // X-GitHub-Delivery header
  event             String   // push, pull_request, installation, etc.
  action            String?  // opened, synchronize, closed, etc.
  payload           Json     // Full webhook payload
  processed         Boolean  @default(false)
  processingError   String?  // Error if processing failed
  triggeredTestRunId String? // Link to the test run triggered by this event
  createdAt         DateTime @default(now())
  processedAt       DateTime?

  installationId String?
  installation   Installation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([event])
  @@index([processed])
  @@index([installationId])
  @@index([createdAt])
}

// ============================================
// Phase 2: Scheduled & Recurring Tests
// ============================================

model Schedule {
  id              String   @id @default(cuid())
  name            String   // Human-readable name, e.g. "Daily Smoke Test"
  url             String   // Target URL to test
  preset          String   @default("smoke") // smoke, navigation, login, form, full-page-screenshot
  cronExpression  String   // Cron expression, e.g. "*/30 * * * *", "0 9 * * 1-5"
  enabled         Boolean  @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?  // passed, failed, error
  lastRunId       String?  // Link to last TestRun
  nextRunAt       DateTime? // Calculated next execution time
  runCount        Int      @default(0)
  failCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  testRuns        TestRun[]

  @@index([userId])
  @@index([enabled])
  @@index([nextRunAt])
}

// ============================================
// Phase 2: Visual Regression Testing
// ============================================

model VisualBaseline {
  id            String   @id @default(cuid())
  name          String   // Human-readable name, e.g. "Homepage Hero", "Login Form"
  url           String   // Page URL that was captured
  selector      String?  // Optional CSS selector for element-specific captures
  viewportWidth  Int     @default(1280)
  viewportHeight Int     @default(720)
  screenshot    String   // Base64-encoded PNG screenshot (the baseline image)
  captureIndex  Int      @default(0) // Step index in test run (for multi-step captures)
  approvedAt    DateTime? // When the baseline was last approved/updated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  diffs     VisualDiff[]

  @@unique([projectId, name, url, selector, viewportWidth, viewportHeight])
  @@index([projectId])
  @@index([userId])
  @@index([url])
}

model VisualDiff {
  id               String   @id @default(cuid())
  status           String   @default("pending") // pending, approved, rejected
  mismatchPercent  Float    @default(0) // Percentage of pixels that differ (0-100)
  mismatchPixels   Int      @default(0) // Raw number of pixels that differ
  totalPixels      Int      @default(0) // Total pixels compared
  threshold        Float    @default(0.1) // Per-pixel difference threshold (0-1)
  currentScreenshot String  // Base64-encoded PNG of the current capture
  diffScreenshot   String?  // Base64-encoded PNG highlighting differences (red pixels)
  reviewNote       String?  // Optional note when approving/rejecting
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  baselineId String
  baseline   VisualBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  testRunId  String?
  testRun    TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([baselineId])
  @@index([projectId])
  @@index([status])
  @@index([testRunId])
  @@index([createdAt])
}

// ============================================
// Phase 2: Notifications & Alerts
// ============================================

model Notification {
  id          String   @id @default(cuid())
  type        String   // test_pass, test_fail, test_error, visual_diff, schedule_complete, auto_heal, webhook_received
  title       String   // Short human-readable title
  message     String   // Detailed message body
  status      String   @default("unread") // unread, read, dismissed
  priority    String   @default("normal") // low, normal, high, critical
  actionUrl   String?  // URL to navigate when clicking the notification (e.g. /dashboard/projects/xxx)
  metadata    Json?    // Additional structured data (testRunId, projectId, etc.)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  testRunId   String?
  testRun     TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([projectId])
}

model NotificationChannel {
  id          String   @id @default(cuid())
  type        String   // email, slack, discord, webhook
  label       String   // User-friendly label, e.g. "Work Slack #testing"
  config      Json     // Channel-specific config: { email: "a@b.com" }, { webhookUrl: "https://hooks.slack.com/..." }
  enabled     Boolean  @default(true)
  verified    Boolean  @default(false) // Whether the channel has been verified (e.g. email confirmed)
  lastError   String?  // Last delivery error, if any
  lastSentAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([enabled])
}

model NotificationPreference {
  id          String   @id @default(cuid())
  eventType   String   // test_pass, test_fail, test_error, visual_diff, schedule_complete, auto_heal, webhook_received
  inApp       Boolean  @default(true)  // Show in-app notification
  email       Boolean  @default(false) // Send email notification
  slack       Boolean  @default(false) // Send Slack notification
  webhook     Boolean  @default(false) // Send to custom webhook
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
}

// ============================================
// Phase 2: Billing & Subscription
// ============================================

model Subscription {
  id                    String   @id @default(cuid())
  plan                  String   @default("free") // free, pro, team, enterprise
  status                String   @default("active") // active, past_due, canceling, canceled, trialing
  currentPeriodStart    DateTime @default(now())
  currentPeriodEnd      DateTime @default(now())
  cancelAtPeriodEnd     Boolean  @default(false)
  trialEndsAt           DateTime?

  // Payment gateway references (filled when Stripe/Paystack account is connected)
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?  @unique
  stripePriceId         String?
  paystackCustomerId    String?  @unique
  paystackSubscriptionCode String? @unique
  paystackPlanCode      String?

  // Gateway used for this subscription
  gateway               String   @default("mock") // mock, stripe, paystack

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@index([stripeCustomerId])
  @@index([paystackCustomerId])
}

model CreditBalance {
  id                String   @id @default(cuid())
  balance           Int      @default(0)   // Current available credits
  monthlyAllowance  Int      @default(20)  // Credits granted per month based on plan
  rolloverBalance   Int      @default(0)   // Accumulated rollover from previous months
  purchasedBalance  Int      @default(0)   // Credits bought via one-time packs (never expire)
  totalUsed         Int      @default(0)   // Lifetime credits used
  totalReceived     Int      @default(0)   // Lifetime credits received

  // Auto-recharge settings
  autoRecharge      Boolean  @default(false)
  autoRechargeThreshold Int  @default(0)   // Trigger when balance drops to this
  autoRechargeAmount    Int  @default(50)  // Credits to add per recharge
  autoRechargeMaxMonthly Int @default(0)   // Max $ to auto-recharge per month (0 = unlimited)

  lastMonthlyReset  DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditTransaction {
  id                String   @id @default(cuid())
  type              String   // credit, debit, reservation, settlement, release, expiry
  amount            Int      // Number of credits (positive)
  balanceAfter      Int      // Balance after this transaction
  action            String   // test_generation, test_execution, feature_discovery, visual_compare, auto_heal, monthly_allowance, credit_pack, auto_recharge, promo, refund, reservation, settlement, release
  description       String   // Human-readable description

  // Link to the resource that caused this transaction
  referenceId       String?  // e.g., testRunId, projectId, stripePaymentIntentId
  referenceType     String?  // test_run, project, payment, schedule, visual_diff

  // Payment gateway reference
  gatewayPaymentId  String?  // Stripe PaymentIntent ID, Paystack reference, etc.

  // For reservations: tracks the state
  reservationStatus String?  // pending, settled, released, expired

  // Metadata
  metadata          Json?

  createdAt         DateTime @default(now())

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([action])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

// ============================================
// Phase 3: Fix Suggestion & Approval Workflow
// ============================================

model FixSuggestion {
  id              String   @id @default(cuid())
  title           String   // Short human-readable description of the fix
  description     String   // Detailed explanation of what the fix does and why
  type            String   // selector_fix, code_fix, config_fix, dependency_fix, assertion_fix
  status          String   @default("pending") // pending, approved, rejected, applied, failed
  confidence      Float    @default(0) // 0-1, AI confidence score for this suggestion
  diff            String?  // Unified diff of the suggested code change
  originalCode    String?  // The original code before the fix
  suggestedCode   String?  // The full suggested replacement code
  reasoning       String?  // AI reasoning for why this fix should work
  appliedAt       DateTime?
  appliedBy       String?  // User ID who approved/applied the fix
  reviewNote      String?  // Optional note when approving/rejecting
  errorMessage    String?  // The original error that triggered this suggestion
  stepIndex       Int?     // Step index in the test run (which step failed)
  metadata        Json?    // Additional structured data (selector info, LLM context, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  testResultId    String
  testResult      TestResult @relation(fields: [testResultId], references: [id], onDelete: Cascade)

  testRunId       String
  testRun         TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  testCaseId      String?  // Link to the test case that would be updated
  testCase        TestCase? @relation(fields: [testCaseId], references: [id], onDelete: SetNull)

  @@index([testResultId])
  @@index([testRunId])
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// Phase 3: Security & Accessibility Testing
// ============================================

model SecurityScan {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, running, completed, failed
  url             String   // URL that was scanned
  overallScore    Int      @default(0) // 0-100 security score
  headersScore    Int      @default(0) // 0-100 headers compliance score
  cspScore        Int      @default(0) // 0-100 CSP score
  mixedContentScore Int    @default(0) // 0-100 mixed content score
  findings        Json     @default("[]") // Array of SecurityFinding objects
  recommendations Json     @default("[]") // Array of recommendation strings
  rawHeaders      Json?    // Raw HTTP headers captured
  llmUsed         Boolean  @default(false)
  duration        Int      @default(0) // ms
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model MediaVerification {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, running, completed, failed
  url             String   // URL that was verified
  overallScore    Int      @default(0) // 0-100 media health score
  imageScore      Int      @default(0) // 0-100 image health score
  videoScore      Int      @default(0) // 0-100 video health score
  audioScore      Int      @default(0) // 0-100 audio health score (reserved for M22)
  imageChecks     Json     @default("[]") // Array of ImageCheckResult objects
  videoChecks     Json     @default("[]") // Array of VideoCheckResult objects
  audioChecks     Json     @default("[]") // Array of AudioCheckResult objects (reserved for M22)
  summary         Json     @default("{}") // Summary statistics
  llmUsed         Boolean  @default(false)
  duration        Int      @default(0) // ms
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model SecurityProbe {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, running, completed, failed
  url             String   // URL that was probed
  overallScore    Int      @default(0) // 0-100 security probe score
  xssScore        Int      @default(0) // 0-100 XSS resistance score
  authScore       Int      @default(0) // 0-100 auth security score
  xssFindings     Json     @default("[]") // Array of XSSProbeFinding objects
  authFindings    Json     @default("[]") // Array of AuthProbeFinding objects
  payloadsTested  Json     @default("[]") // XSS payloads that were tested
  authEndpoints   Json     @default("[]") // Auth endpoints that were probed
  recommendations Json     @default("[]") // Array of recommendation strings
  llmUsed         Boolean  @default(false)
  duration        Int      @default(0) // ms
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model APIProbe {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, running, completed, failed
  url             String   // Base URL that was probed
  overallScore    Int      @default(0) // 0-100 API security score
  apiSecurityScore Int     @default(0) // 0-100 API endpoint security score
  csrfScore       Int      @default(0) // 0-100 CSRF protection score
  rateLimitScore  Int      @default(0) // 0-100 rate limiting score
  idorScore       Int      @default(0) // 0-100 IDOR protection score
  apiFindings     Json     @default("[]") // Array of APISecurityFinding objects
  csrfFindings    Json     @default("[]") // Array of CSRFFinding objects
  rateLimitFindings Json   @default("[]") // Array of RateLimitFinding objects
  idorFindings    Json     @default("[]") // Array of IDORFinding objects
  endpoints       Json     @default("[]") // Discovered API endpoints
  recommendations Json     @default("[]") // Array of recommendation strings
  llmUsed         Boolean  @default(false)
  duration        Int      @default(0) // ms
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model A11yAudit {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, running, completed, failed
  url             String   // URL that was audited
  overallScore    Int      @default(0) // 0-100 accessibility score
  wcagLevel       String   @default("AA") // A, AA, AAA
  violations      Json     @default("[]") // Array of A11yViolation objects
  passes          Json     @default("[]") // Array of passing checks
  incomplete      Json     @default("[]") // Array of incomplete checks
  recommendations Json     @default("[]") // Array of recommendation strings
  llmUsed         Boolean  @default(false)
  duration        Int      @default(0) // ms
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// Phase 2: Public API & Developer SDK
// ============================================

model ApiKey {
  id                String   @id @default(cuid())
  name              String   // Human-readable label, e.g. "CI/CD Pipeline", "Dev Machine"
  prefix            String   // First 8 chars of the key for identification (e.g. "pb_live_")
  keyHash           String   @unique // Scrypt hash of the full API key
  scopes            Json     @default("{\"scopes\":[\"read\"]}") // ["read", "write", "admin", "billing"]
  enabled           Boolean  @default(true)
  lastUsedAt        DateTime?
  expiresAt         DateTime? // Optional expiration date
  rateLimitOverride Int?     // Custom rate limit (requests/min) overriding plan default

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  usage             ApiUsage[]

  @@index([userId])
  @@index([prefix])
  @@index([keyHash])
  @@index([enabled])
}

model ApiUsage {
  id              String   @id @default(cuid())
  apiKeyId        String
  userId          String
  endpoint        String   // e.g. "POST /api/v1/discover"
  method          String   // GET, POST, PATCH, DELETE
  statusCode      Int      // HTTP response status code
  creditsUsed     Int      @default(0) // Credits consumed by this request
  responseTime    Int?     // Response time in milliseconds
  userAgent       String?  // Client User-Agent header
  ipAddress       String?  // Client IP address
  errorMessage    String?  // Error message if request failed

  createdAt       DateTime @default(now())

  apiKey          ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
  @@index([statusCode])
}

// ============================================
// Phase 3: Onboarding State
// ============================================

model OnboardingState {
  id              String   @id @default(cuid())
  currentStep     String   @default("welcome") // welcome, connect_repo, discover, first_test, complete
  completedSteps  String[] @default([])
  skipped         Boolean  @default(false)
  repoUrl         String?  // Repo URL entered during onboarding
  projectId       String?  // Project created during onboarding
  featureCount    Int      @default(0)
  testRunId       String?  // First test run from onboarding
  dismissedAt     DateTime? // When user dismissed/skipped onboarding
  completedAt     DateTime? // When user completed all onboarding steps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentStep])
}

// ============================================
// Phase 3: Team Collaboration & Sharing
// ============================================

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL-friendly team name
  description String?
  avatarUrl   String?  // Team avatar/logo URL
  plan        String   @default("team") // Team plan slug
  maxMembers  Int      @default(10) // Max members allowed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerUserId String
  owner       User     @relation("OwnedTeams", fields: [ownerUserId], references: [id], onDelete: Cascade)

  members     TeamMember[]
  invitations TeamInvitation[]
  projects    Project[]
  ssoConfiguration   SSOConfiguration?
  auditLogs          AuditLog[]
  auditLogExports    AuditLogExport[]
  permissionPolicies PermissionPolicy[]
  plugins            Plugin[]

  @@index([ownerUserId])
  @@index([slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  role      String   @default("member") // owner, admin, member, viewer
  status    String   @default("active") // active, suspended, removed
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
}

model TeamInvitation {
  id          String    @id @default(cuid())
  email       String    // Email of the invited user
  role        String    @default("member") // admin, member, viewer
  token       String    @unique // Secure invitation token
  status      String    @default("pending") // pending, accepted, declined, expired, cancelled
  message     String?   // Optional personal message from inviter
  expiresAt   DateTime  // When the invitation expires
  acceptedAt  DateTime?
  declinedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User  @relation("SentInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  invitedUserId   String?
  invitedUser     User? @relation("ReceivedInvitations", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

model SharedProject {
  id          String   @id @default(cuid())
  permission  String   @default("view") // view, edit, admin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sharedByUserId String
  sharedBy       User   @relation("SharedWithUser", fields: [sharedByUserId], references: [id], onDelete: Cascade)

  sharedWithUserId String
  sharedWithUser   User  @relation("SharedProjects", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([projectId, sharedWithUserId])
  @@index([projectId])
  @@index([sharedByUserId])
  @@index([sharedWithUserId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   // Comment text (markdown supported)
  resolved  Boolean  @default(false) // Whether the comment/thread is resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId String?  // Optional: link to a specific test run
  testRun   TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  parentId  String?  // For threaded replies
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([projectId])
  @@index([userId])
  @@index([testRunId])
  @@index([parentId])
  @@index([createdAt])
}

// ============================================
// M20: Test Intelligence Models
// ============================================

model FeatureRiskScore {
  id              String   @id @default(cuid())
  featureId       String
  feature         Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  riskScore       Float    @default(0)   // 0-100 composite risk score
  flakeRate       Float    @default(0)   // 0-1 ratio of intermittent failures
  failRate        Float    @default(0)   // 0-1 ratio of total failures
  avgDuration     Float    @default(0)   // average test duration in ms
  lastFailedAt    DateTime?              // when this feature's test last failed
  autoHealCount   Int      @default(0)   // number of auto-heal events
  failCluster     String?               // categorized failure reason (selector, timeout, assertion, etc.)

  computedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([featureId])
  @@index([riskScore])
  @@index([flakeRate])
  @@index([failRate])
}

// ============================================
// Phase 5: Multi-Device Orchestration (M25)
// ============================================

model OrchestratedSession {
  id              String    @id @default(cuid())
  scenarioType    String    @default("custom")  // messaging, call, payment, custom
  status          String    @default("pending")  // pending, running, completed, failed, aborted
  url             String    // Target URL for the orchestrated test
  config          Json      @default("{}")       // Scenario config (agents, sync points, options)
  overallScore    Int       @default(0)           // 0-100 aggregated score
  agentResults    Json      @default("{}")        // Per-agent results
  summary         String?                         // AI-generated summary
  findings        Json      @default("[]")        // Aggregated findings across agents
  recommendations Json      @default("[]")        // Array of recommendation strings
  llmUsed         Boolean   @default(false)
  duration        Int       @default(0)           // Total session duration in ms
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  testRunId       String?
  testRun         TestRun?  @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  sandboxes       SandboxInstance[]
  syncEvents      SyncEvent[]
  messagingTest   MessagingTestSession?
  callFlowTest    CallFlowTestSession?
  paymentFlowTest PaymentFlowTestSession?

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([scenarioType])
  @@index([createdAt])
}

model SandboxInstance {
  id              String              @id @default(cuid())
  agentRole       String              // sender, receiver, caller, callee, payer, merchant, observer
  browserId       String?             // Browser instance identifier
  status          String              @default("provisioning")  // provisioning, ready, running, done, error
  actions         Json                @default("[]")  // Assigned action sequence
  results         Json                @default("[]")  // Step-by-step results
  score           Int                 @default(0)     // 0-100 per-agent score
  errorLog        String?             // Error details if failed
  screenshotUrl   String?             // Screenshot of final state
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  sessionId       String
  session         OrchestratedSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
  @@index([agentRole])
}

model SyncEvent {
  id              String              @id @default(cuid())
  eventType       String              // barrier, signal, state_update, error, release
  sourceAgent     String              // Agent role that produced the event
  targetAgent     String?             // Target agent role (null = broadcast)
  payload         Json                @default("{}")  // Event data
  consumed        Boolean             @default(false)
  consumedAt      DateTime?
  createdAt       DateTime            @default(now())

  sessionId       String
  session         OrchestratedSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, eventType])
  @@index([sessionId, targetAgent, consumed])
  @@index([consumed])
}

// ============================================
