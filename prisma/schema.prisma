  calleeIdentifier    String    @default("PROBATO_CALLEE_2024") // Callee identifier used for testing
  callType            String    @default("audio")  // audio, video, screen_share
  ringLatencyMs       Int       @default(0)           // Time from dial to ring indicator
  connectionLatencyMs Int       @default(0)           // Time from answer to connected state
